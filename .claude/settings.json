{
  "permissions": {
    "allow": [
      "Edit(/.claude/skills/frontend/**)",
      "Edit(/.claude/skills/infra/**)",
      "Bash(mkdir -p \".claude/examples/framework-profiles/nextjs\" \".claude/examples/framework-profiles/express\" \".claude/examples/framework-profiles/postgres\" \".claude/examples/framework-profiles/vue\" \".claude/examples/framework-profiles/terraform\")",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git add *)",
      "Edit(/.claude/skills/general/**)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "additionalDirectories": [
      "e:\\GitProject\\claude-code-setup\\.claude\\skills\\infra"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-agent-skill-call.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-run-tests.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-run-fast-tests.sh"
          }
        ]
      }
    ]
  }
}
